    "custom_liquid_tMfpE4": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "<div style=\"margin: 24px 0;\">\n\n  <h3 style=\"text-align: center; font-size: 16px; font-weight: 800; color: #111; margin: 0 0 6px 0; text-transform: uppercase; letter-spacing: 0.05em;\">Wissenschaftlich bewiesene Inhaltsstoffe</h3>\n  <p style=\"text-align: center; font-size: 13px; color: #6b7280; margin: 0 0 18px 0;\">für messbare Ergebnisse</p>\n\n  <!-- INGREDIENT 1 -->\n  <div style=\"display: flex; align-items: center; gap: 14px; background: #fafafa; border-radius: 10px; padding: 14px; margin-bottom: 10px; border-left: 3px solid #cb4b45;\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0814/7897/5709/files/ChatGPT_Image_11_mars_2026_16_40_52_430x.png?v=1773261783\"\n      style=\"width: 64px; height: 64px; object-fit: cover; border-radius: 8px; flex-shrink: 0;\" />\n    <div>\n      <p style=\"margin: 0 0 3px 0; font-size: 13px; font-weight: 800; color: #111;\">Cayennepfeffer-Extrakt</p>\n      <p style=\"margin: 0; font-size: 12px; color: #6b7280; line-height: 1.5;\">Unterstützt die Durchblutung und fördert die natürliche Energie durch Vasodilatation.</p>\n    </div>\n  </div>\n\n  <!-- INGREDIENT 2 -->\n  <div style=\"display: flex; align-items: center; gap: 14px; background: #fafafa; border-radius: 10px; padding: 14px; margin-bottom: 10px; border-left: 3px solid #cb4b45;\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0814/7897/5709/files/ChatGPT_Image_11_mars_2026_16_41_46_430x.png?v=1773261783\"\n      style=\"width: 64px; height: 64px; object-fit: cover; border-radius: 8px; flex-shrink: 0;\" />\n    <div>\n      <p style=\"margin: 0 0 3px 0; font-size: 13px; font-weight: 800; color: #111;\">Rote-Bete-Extrakt</p>\n      <p style=\"margin: 0; font-size: 12px; color: #6b7280; line-height: 1.5;\">Steigert die Stickoxid-Produktion und verbessert die Gefäßfunktion nachweislich.</p>\n    </div>\n  </div>\n\n  <!-- INGREDIENT 3 -->\n  <div style=\"display: flex; align-items: center; gap: 14px; background: #fafafa; border-radius: 10px; padding: 14px; margin-bottom: 10px; border-left: 3px solid #cb4b45;\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0814/7897/5709/files/ChatGPT_Image_11_mars_2026_16_41_15_430x.png?v=1773261783\"\n      style=\"width: 64px; height: 64px; object-fit: cover; border-radius: 8px; flex-shrink: 0;\" />\n    <div>\n      <p style=\"margin: 0 0 3px 0; font-size: 13px; font-weight: 800; color: #111;\">Kurkuma-Extrakt</p>\n      <p style=\"margin: 0; font-size: 12px; color: #6b7280; line-height: 1.5;\">Verhindert Sodbrennen und Magenprobleme — macht die Einnahme täglich angenehm.</p>\n    </div>\n  </div>\n\n  <!-- INGREDIENT 4 -->\n  <div style=\"display: flex; align-items: center; gap: 14px; background: #fafafa; border-radius: 10px; padding: 14px; margin-bottom: 10px; border-left: 3px solid #cb4b45;\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0814/7897/5709/files/ChatGPT_Image_11_mars_2026_16_43_04_430x.png?v=1773261803\"\n      style=\"width: 64px; height: 64px; object-fit: cover; border-radius: 8px; flex-shrink: 0;\" />\n    <div>\n      <p style=\"margin: 0 0 3px 0; font-size: 13px; font-weight: 800; color: #111;\">Vitamine D3, K2 & E</p>\n      <p style=\"margin: 0; font-size: 12px; color: #6b7280; line-height: 1.5;\">Essenzielle Nährstoffe für Immunsystem, Knochengesundheit und antioxidativen Schutz.</p>\n    </div>\n  </div>\n\n  <!-- DISCLAIMER -->\n  <p style=\"margin: 12px 0 0 0; font-size: 11px; color: #9ca3af; font-style: italic; text-align: center;\">\n    * Konsultieren Sie einen Arzt, wenn Sie dieses Produkt zusammen mit anderen Medikamenten einnehmen.\n  </p>\n\n</div>",
        "background": "",
