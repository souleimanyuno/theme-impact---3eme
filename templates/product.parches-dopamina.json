        "liquid": "<div style=\"margin: 20px 0; border-radius: 12px; overflow: hidden; position: relative;\">\n\n  <!-- TITRE -->\n  <h3 style=\"text-align: center; font-size: 16px; font-weight: 800; color: #111; margin: 0 0 14px 0; text-transform: uppercase; letter-spacing: 0.05em;\">Vorher & Nachher</h3>\n\n  <!-- IMAGE AVEC SLIDER -->\n  <div id=\"ba-container\" style=\"position: relative; width: 100%; overflow: hidden; border-radius: 10px; cursor: col-resize; user-select: none;\">\n\n    <!-- IMAGE AFTER (fond) -->\n    <img src=\"https://cdn.shopify.com/s/files/1/0814/7897/5709/files/NELORYA_11_430x.png?v=1773261018\"\n      style=\"width: 100%; display: block;\" />\n\n    <!-- IMAGE BEFORE (overlay gauche) -->\n    <div id=\"ba-before\" style=\"position: absolute; top: 0; left: 0; width: 50%; height: 100%; overflow: hidden;\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0814/7897/5709/files/NELORYA_11_430x.png?v=1773261018\"\n        style=\"width: 100vw; max-width: none; display: block; filter: grayscale(100%) brightness(0.7);\" />\n    </div>\n\n    <!-- LIGNE SEPARATRICE -->\n    <div id=\"ba-line\" style=\"position: absolute; top: 0; left: 50%; width: 3px; height: 100%; background: #fff; transform: translateX(-50%); pointer-events: none;\">\n      <!-- HANDLE -->\n      <div style=\"position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 36px; height: 36px; background: #cb4b45; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 8px rgba(0,0,0,0.3);\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fff\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"15 18 9 12 15 6\"/></svg>\n      </div>\n    </div>\n\n    <!-- LABELS -->\n    <div style=\"position: absolute; top: 10px; left: 10px; background: rgba(0,0,0,0.6); color: #fff; font-size: 11px; font-weight: 700; padding: 3px 8px; border-radius: 4px;\">VORHER</div>\n    <div style=\"position: absolute; top: 10px; right: 10px; background: #cb4b45; color: #fff; font-size: 11px; font-weight: 700; padding: 3px 8px; border-radius: 4px;\">NACHHER</div>\n\n  </div>\n\n  <!-- TEXTE BAS -->\n<div style=\"margin: 20px 0; padding: 16px; background: #fafafa; border-left: 3px solid #cb4b45; border-radius: 6px;\">\n\n  <h3 style=\"margin: 0 0 8px 0; font-size: 15px; font-weight: 800; color: #111;\">Der einzigartige Wirkmechanismus</h3>\n\n  <p style=\"margin: 0 0 14px 0; font-size: 13px; color: #374151; line-height: 1.6;\">\n    Capsaicin ist die einzige Verbindung, die die innere Wand Ihrer Blutgefäße aktiv repariert — und so die natürliche Produktion von Stickoxid wiederherstellt.\n  </p>\n\n  <div style=\"display: flex; flex-direction: column; gap: 10px;\">\n\n    <div style=\"display: flex; align-items: flex-start; gap: 10px;\">\n      <div style=\"background: #cb4b45; color: #fff; font-size: 11px; font-weight: 800; border-radius: 50%; width: 22px; height: 22px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\">1</div>\n      <div>\n        <p style=\"margin: 0; font-size: 13px; font-weight: 700; color: #111;\">Aktivieren</p>\n        <p style=\"margin: 0; font-size: 12px; color: #6b7280;\">Capsaicin aktiviert TRPV1-Rezeptoren in den Gefäßwänden.</p>\n      </div>\n    </div>\n\n    <div style=\"display: flex; align-items: flex-start; gap: 10px;\">\n      <div style=\"background: #cb4b45; color: #fff; font-size: 11px; font-weight: 800; border-radius: 50%; width: 22px; height: 22px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\">2</div>\n      <div>\n        <p style=\"margin: 0; font-size: 13px; font-weight: 700; color: #111;\">Reparieren</p>\n        <p style=\"margin: 0; font-size: 12px; color: #6b7280;\">Reduziert Entzündungen und stellt die Stickoxid-Produktion wieder her.</p>\n      </div>\n    </div>\n\n    <div style=\"display: flex; align-items: flex-start; gap: 10px;\">\n      <div style=\"background: #cb4b45; color: #fff; font-size: 11px; font-weight: 800; border-radius: 50%; width: 22px; height: 22px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\">3</div>\n      <div>\n        <p style=\"margin: 0; font-size: 13px; font-weight: 700; color: #111;\">Wiederherstellen</p>\n        <p style=\"margin: 0; font-size: 12px; color: #6b7280;\">Gesunde Durchblutung, flexible Arterien, natürliche Vasodilatation.</p>\n      </div>\n    </div>\n\n  </div>\n\n</div>\n</script>",
